# Copy to .env and fill in. Used by jobintel CLI.

# SMTP (Gmail: use an App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=
MAIL_FROM=you@gmail.com
MAIL_TO=you@gmail.com

# Optional: Adzuna (free tier) for UK / US / Canada — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Set to 0 to skip Adzuna when keys are empty
ADZUNA_ENABLED=1
